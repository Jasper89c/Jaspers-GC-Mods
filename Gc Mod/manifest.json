{
  "manifest_version": 3,
  "name": "Jaspers GC Mods",
  "version": "3.4",
  "permissions": [
    "storage",
    "webRequest",
    "declarativeNetRequest"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "splitview_framing",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "host_permissions": [
    "https://api.github.com/*",
    "*://gcc.wrindustries.com/*"
  ],
  "options_ui": {
    "page": "dashboard.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://gcc.wrindustries.com/*"],
      "js": [
        "features/globals.js",
        "features/themes.js",
        "features/logger.js",
        "features/automation.js",
        "features/cluster.js",
        "features/federation.js",
        "features/nav-links.js",
        "features/ship-builder.js",
        "features/ship-tooltips.js",
        "features/disband.js",
        "features/colony.js",
        "features/market.js",
        "features/income.js",
        "features/updates.js",
        "features/chat.js",
        "features/artifact-tracker.js",
        "features/quick-build.js",
        "features/battle-logs.js",
        "features/colupgrade-land.js",
        "features/panel.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard.html",
        "dashboard.js",
        "splitview.html",
        "splitview.js",
        "ecosim.html",
        "ecosim.js"
      ],
      "matches": [
        "https://gcc.wrindustries.com/*"
      ]
    }
  ]
}