{
  "manifest_version": 3,
  "name": "Jaspers GC Mods",
  "version": "2.2",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "*://gcc.wrindustries.com/*"
  ],
  "options_ui": {
    "page": "dashboard.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://gcc.wrindustries.com/*"],
      "js": [
        "features/globals.js",
        "features/automation.js",
        "features/cluster.js",
        "features/federation.js",
        "features/nav-links.js",
        "features/ship-builder.js",
        "features/ship-tooltips.js",
        "features/disband.js",
        "features/colony.js",
        "features/updates.js",
        "features/chat.js",
        "features/quick-build.js",
        "features/battle-logs.js",
        "features/panel.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard.html",
        "dashboard.js"
      ],
      "matches": [
        "https://gcc.wrindustries.com/*"
      ]
    }
  ]
}